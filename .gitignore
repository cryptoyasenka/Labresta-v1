claude-acc*.bat

# Python
__pycache__/
*.pyc
*.pyo
dist/
*.egg-info/

# Flask instance folder (SQLite DB)
instance/

# Local DB backups
backups/

# Environment
.env

# Ruff
.ruff_cache/

# uv
.venv/

# Claude Code local config
.claude/

# Local reports / audit dumps
reports/
audit_*.json
audit_*.txt
red_*.json
red_*.txt
np_*.json
np_*.txt

# Windows redirect artefact
nul

